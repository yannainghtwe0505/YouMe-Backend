{
  "info": {
    "name": "Dating App API",
    "_postman_id": "d1a-collection",
    "description": "Set collection variable baseUrl (e.g. http://192.168.1.55:8090). See docs/ENVIRONMENT_URLS.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"alice2@example.com\",\"password\":\"password\"}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"alice2@example.com\",\"password\":\"password\"}"
        }
      }
    },
    {
      "name": "Me:Get",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/me"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://192.168.1.55:8090"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}