        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/auth/login",
          "host": [
            "http://localhost:8080"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
